---
import Base from '../layouts/Base.astro';
import LeaderboardTable from '../components/LeaderboardTable.astro';

const modelsRaw = await import('../../data/models.json');
const models = modelsRaw.default || modelsRaw;
const base = import.meta.env.BASE_URL;

const categories = ['All', ...models.categories];
const report = models.weekly_report;
const trend = models.trend_data;

// Compute bar widths: normalize scores to percentage of max across all series
const allScores = trend.series.flatMap((s: any) => s.scores);
const maxScore = Math.max(...allScores);
const minScore = Math.min(...allScores) - 20; // give some offset for visual clarity
const range = maxScore - minScore;

const seriesColors = ['#2563eb', '#ef4444', '#10b981'];
---

<Base title="Model Leaderboard · The Digest" current="Models">
  <main style="overflow-x: hidden;">
    <!-- Header -->
    <div class="max-w-[1120px] mx-auto px-12">
      <section class="py-12 pb-10 border-b border-[var(--border)]">
        <h1 class="text-[36px] font-extrabold tracking-tight text-[var(--text)] mb-3">Model Leaderboard</h1>
        <p class="text-[15px] text-[var(--text-2)] leading-relaxed max-w-[640px] mb-5">
          Cross-category, cross-platform AI model rankings. Aggregated from multiple authoritative benchmarks — updated weekly.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">Updated {models.last_updated}</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{models.rankings.length} models</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{models.categories.length} categories</span>
        </div>
      </section>
    </div>

    <!-- Category Tabs + Table -->
    <div class="max-w-[1120px] mx-auto px-12 py-10">
      <div class="flex flex-wrap gap-2 mb-8">
        {categories.map((cat: string, i: number) => (
          <button
            data-filter-tab={cat}
            class:list={[
              'text-xs font-medium px-4 py-1.5 rounded-full transition-colors',
              i === 0 ? 'filter-active' : 'filter-inactive',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="bg-[var(--bg-card)] rounded-[18px] shadow-[var(--shadow)] overflow-hidden">
        <LeaderboardTable rankings={models.rankings} />
      </div>
    </div>

    <!-- Weekly Report -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-4 font-medium">Weekly AI Analysis</div>
        <h2 class="text-[24px] font-bold text-[var(--text)] mb-2">{report.title}</h2>
        <p class="text-xs text-[var(--text-3)] mb-8">{report.date}</p>

        {report.sections.map((section: any) => {
          if (section.type === 'comparison') {
            return (
              <div class="mb-10">
                <h3 class="text-[18px] font-bold text-[var(--text)] mb-5">{section.heading}</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                  {section.models.map((m: any) => (
                    <div class="bg-[var(--bg-card)] rounded-[14px] shadow-[var(--shadow)] p-6 flex flex-col">
                      <div class="mb-4">
                        <div class="text-[16px] font-bold text-[var(--text)]">{m.name}</div>
                        <div class="text-xs text-[var(--text-3)]">{m.org}</div>
                      </div>
                      <div class="mb-3">
                        <div class="text-[11px] uppercase tracking-wider text-green-600 font-semibold mb-1.5">Strengths</div>
                        <ul class="list-none p-0 m-0 space-y-1">
                          {m.strengths.map((s: string) => (
                            <li class="text-[13px] text-[var(--text-2)] leading-snug flex items-start gap-1.5">
                              <span class="text-green-500 mt-0.5 shrink-0">+</span>
                              <span>{s}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                      <div class="mb-4">
                        <div class="text-[11px] uppercase tracking-wider text-amber-600 font-semibold mb-1.5">Weaknesses</div>
                        <ul class="list-none p-0 m-0 space-y-1">
                          {m.weaknesses.map((w: string) => (
                            <li class="text-[13px] text-[var(--text-2)] leading-snug flex items-start gap-1.5">
                              <span class="text-amber-500 mt-0.5 shrink-0">-</span>
                              <span>{w}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                      <div class="mt-auto pt-3 border-t border-[var(--border)]">
                        <div class="text-[11px] uppercase tracking-wider text-[var(--text-3)] font-semibold mb-1">Best for</div>
                        <p class="text-[13px] text-[var(--text-2)] leading-snug m-0">{m.best_for}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            );
          }
          return (
            <div class="mb-10">
              <h3 class="text-[18px] font-bold text-[var(--text)] mb-4">{section.heading}</h3>
              <div class="bg-[var(--bg-card)] rounded-[14px] shadow-[var(--shadow)] p-7">
                <div class="report-body text-[15px] text-[var(--text-2)] leading-[1.9]" set:html={
                  section.body
                    .split('\n\n')
                    .map((para: string) => {
                      // Check if paragraph is a list (all lines start with "- ")
                      const lines = para.split('\n');
                      const isList = lines.every((l: string) => l.startsWith('- '));
                      if (isList) {
                        const items = lines.map((l: string) => `<li>${l.slice(2).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}</li>`).join('');
                        return `<ul class="report-list">${items}</ul>`;
                      }
                      return `<p>${para.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')}</p>`;
                    })
                    .join('')
                } />
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Elo Trend Chart (CSS-only) -->
    <div class="max-w-[1120px] mx-auto px-12 py-12">
      <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Elo Trend</div>
      <div class="bg-[var(--bg-card)] rounded-[18px] shadow-[var(--shadow)] p-8">
        <!-- Legend -->
        <div class="flex gap-6 mb-6">
          {trend.series.map((s: any, i: number) => (
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full" style={`background: ${seriesColors[i]};`} />
              <span class="text-xs font-medium text-[var(--text-2)]">{s.model}</span>
            </div>
          ))}
        </div>
        <!-- Chart -->
        <div class="flex items-end gap-3">
          {trend.weeks.map((week: string, wi: number) => (
            <div class="flex-1 flex flex-col items-center gap-1">
              <div class="flex items-end gap-[2px] h-[160px]">
                {trend.series.map((s: any, si: number) => {
                  const score = s.scores[wi];
                  const pct = Math.round(((score - minScore) / range) * 100);
                  return (
                    <div class="flex flex-col items-center" style={`height: 100%; justify-content: flex-end;`}>
                      <span class="text-[9px] font-medium mb-1" style={`color: ${seriesColors[si]};`}>{score}</span>
                      <div
                        class="w-4 rounded-t-[3px] transition-all"
                        style={`height: ${pct}%; background: ${seriesColors[si]}; min-height: 4px;`}
                        title={`${s.model}: ${score}`}
                      />
                    </div>
                  );
                })}
              </div>
              <span class="text-[10px] text-[var(--text-3)] mt-1">{week}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Data Sources -->
    <div class="max-w-[1120px] mx-auto px-12 pb-12">
      <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-4 font-medium">Data Sources</div>
      <div class="flex flex-wrap gap-2">
        {models.data_sources.map((src: string) => (
          <span class="text-xs px-3.5 py-1.5 rounded-full bg-[var(--bg-card)] shadow-[var(--shadow)] text-[var(--text-2)] font-medium">
            {src}
          </span>
        ))}
      </div>
    </div>
  </main>

  <style>
    .filter-active {
      background: var(--accent);
      color: white;
    }
    .filter-inactive {
      background: var(--accent-bg);
      color: var(--text-3);
    }
    .filter-inactive:hover {
      background: var(--accent);
      color: white;
      opacity: 0.7;
    }
    .report-body p {
      margin: 0 0 1em 0;
    }
    .report-body p:last-child {
      margin-bottom: 0;
    }
    .report-body strong {
      color: var(--text);
      font-weight: 600;
    }
    .report-body .report-list {
      list-style: none;
      padding: 0;
      margin: 0 0 1em 0;
    }
    .report-body .report-list li {
      position: relative;
      padding-left: 1.2em;
      margin-bottom: 0.4em;
    }
    .report-body .report-list li::before {
      content: "\2022";
      position: absolute;
      left: 0;
      color: var(--text-3);
    }
  </style>

  <script is:inline src={`${base}scripts/filter.js`}></script>
  <script is:inline src={`${base}scripts/sort.js`}></script>
</Base>
