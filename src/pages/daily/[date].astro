---
import Base from '../../layouts/Base.astro';
import DigestCard from '../../components/DigestCard.astro';
import StoryRow from '../../components/StoryRow.astro';
import QuoteCard from '../../components/QuoteCard.astro';
import PerspectiveBlock from '../../components/PerspectiveBlock.astro';
import ModelFlashTable from '../../components/ModelFlashTable.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import MapView from '../../components/MapView.astro';
import CategoryPill from '../../components/CategoryPill.astro';

export async function getStaticPaths() {
  const files = import.meta.glob('../../../data/daily/*.json', { eager: true });
  const entries = Object.entries(files)
    .map(([path, mod]: [string, any]) => {
      const d = mod.default || mod;
      return d;
    })
    .sort((a: any, b: any) => a.date.localeCompare(b.date));

  return entries.map((d: any, i: number) => ({
    params: { date: d.date },
    props: {
      data: d,
      prevDate: i > 0 ? entries[i - 1].date : null,
      nextDate: i < entries.length - 1 ? entries[i + 1].date : null,
    },
  }));
}

const { data, prevDate, nextDate } = Astro.props;
const base = import.meta.env.BASE_URL;

// Map model_flash fields to component expected props
const modelFlashData = data.model_flash.map((row: any) => ({
  category: row.category,
  closedSource: row.best_closed,
  openSource: row.best_open,
  bestValue: row.best_value,
  change: row.change,
}));

// Hotspot color mapping
const dotColors: Record<string, string> = { red: '#ef4444', amber: '#f59e0b', green: '#10b981', violet: '#8b5cf6' };
const hotspotsWithColors = data.map_hotspots.map((spot: any) => ({
  ...spot,
  dotColor: dotColors[spot.color] || '#6b7280',
}));
---

<Base title={`${data.date} · The Digest #${data.issue}`} current="Archive">
  <main style="overflow-x: hidden;">
    <!-- Breadcrumb -->
    <div class="max-w-[1120px] mx-auto px-12 pt-8 pb-2">
      <nav class="flex items-center gap-2 text-xs text-[var(--text-3)]">
        <a href={`${base}archive`} class="hover:text-[var(--accent)] no-underline text-[var(--text-3)]">Archive</a>
        <span>/</span>
        <span class="text-[var(--text)]">{data.date}</span>
      </nav>
    </div>

    <!-- Hero -->
    <div class="max-w-[1120px] mx-auto px-12">
      <section class="py-8 pb-12">
        <span class="inline-flex items-center gap-2 text-xs font-semibold text-red-500 bg-red-50 dark:bg-red-950/30 px-3.5 py-1 rounded-full mb-6">
          <span style="width:7px;height:7px;border-radius:50%;background:#ef4444;"></span>
          Issue {data.issue}
        </span>
        <h1 class="text-[36px] font-extrabold tracking-tight leading-[1.28] max-w-[860px] text-[var(--text)]">
          {data.headline}
        </h1>
        <p class="text-[16px] leading-[1.9] text-[var(--text-2)] max-w-[800px] mt-4 mb-6">
          {data.summary}
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.date}</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.meta.article_count} articles</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.meta.source_count} sources</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.meta.reading_minutes} min read</span>
        </div>
      </section>
    </div>

    <!-- Today's Brief + More Stories -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Today's Brief</div>
        <div class="grid grid-cols-3 gap-[18px] mb-6">
          {data.highlights.map((h: any) => (
            <DigestCard
              category={h.category}
              title={h.title}
              summary={h.summary}
              sources={h.sources.join(' · ')}
              url={h.url}
            />
          ))}
        </div>
        <div class="h-px bg-[var(--border)] my-4"></div>
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-4 font-medium">More Stories</div>
        <div class="flex flex-col gap-0.5">
          {data.stories.map((s: any) => (
            <StoryRow
              category={s.category}
              title={s.title}
              sourceCount={s.source_count}
              importance={s.importance}
              url={s.url}
            />
          ))}
        </div>
      </div>
    </div>

    <!-- In-Depth Reports -->
    {data.articles && data.articles.length > 0 && (
      <div class="max-w-[1120px] mx-auto px-12 py-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">In-Depth Reports</div>
        <div class="grid grid-cols-2 gap-5">
          {data.articles.map((article: any) => (
            <a href={`${base}daily/${data.date}/${article.slug}`} class="article-card block bg-[var(--bg-card)] rounded-[18px] shadow-[var(--shadow)] p-6 no-underline transition-all">
              <div class="flex items-center gap-3 mb-3">
                <CategoryPill category={article.category} />
                <span class="text-xs text-[var(--text-3)]">{article.reading_minutes} min read</span>
              </div>
              <h3 class="text-[15px] font-semibold text-[var(--text)] leading-snug mb-2">{article.title}</h3>
              <p class="text-[13px] text-[var(--text-2)] leading-relaxed m-0 line-clamp-3">{article.summary}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Geopolitical Hotspots -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Geopolitical Hotspots</div>
        <div class="mb-8">
          <MapView hotspots={data.map_hotspots} />
        </div>
        <div class="grid grid-cols-4 gap-4">
          {hotspotsWithColors.map((spot: any) => (
            <div class="rounded-[14px] bg-[var(--bg-card)] shadow-sm p-4">
              <div class="flex items-center gap-2 mb-2">
                <span style={`width:8px;height:8px;border-radius:50%;background:${spot.dotColor};box-shadow:0 0 6px ${spot.dotColor};flex-shrink:0;`}></span>
                <span class="text-sm font-semibold text-[var(--text)]">{spot.title}</span>
              </div>
              <p class="text-xs text-[var(--text-2)] leading-relaxed m-0">{spot.summary}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Cross-Source Perspectives -->
    <div class="max-w-[1120px] mx-auto px-12 py-12">
      <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Cross-Source Perspectives</div>
      <div class="flex flex-col gap-12">
        {data.perspectives.map((p: any) => (
          <PerspectiveBlock
            title={p.title}
            subtitle={p.subtitle}
            eventSlug={p.event_slug}
            sources={p.sources}
          />
        ))}
      </div>
    </div>

    <!-- Notable Quotes -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Notable Quotes</div>
        <div class="grid grid-cols-2 gap-5">
          {data.quotes.map((q: any) => (
            <QuoteCard
              personName={q.person_name}
              personSlug={q.person_slug}
              text={q.text}
              source={q.source}
              date={q.date}
            />
          ))}
        </div>
      </div>
    </div>

    <!-- Event Updates -->
    <div class="max-w-[1120px] mx-auto px-12 py-12">
      <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Event Updates</div>
      <div class="flex flex-col gap-3">
        {data.event_updates.map((evt: any) => (
          <a href={`${base}events/${evt.event_slug}`} class="flex items-center gap-4 p-4 rounded-[14px] bg-[var(--bg-card)] shadow-sm no-underline hover:opacity-90 transition-opacity">
            <StatusBadge status={evt.status} />
            <span class="font-semibold text-sm text-[var(--text)]">{evt.title}</span>
            <span class="flex-1 text-sm text-[var(--text-2)] truncate">{evt.latest_summary}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Model Leaderboard Flash -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Model Leaderboard Flash</div>
        <ModelFlashTable data={modelFlashData} baseUrl={base} />
      </div>
    </div>

    <!-- Prev/Next Navigation -->
    <div class="max-w-[1120px] mx-auto px-12">
      <footer class="border-t border-[var(--border)] py-6 flex justify-between items-center">
        <span class="text-xs text-[var(--text-3)]">Generated at 07:00 NZST · Powered by Cowork</span>
        <div class="flex gap-2">
          {prevDate && (
            <a href={`${base}daily/${prevDate}`} class="text-xs text-[var(--text-3)] no-underline px-3.5 py-1.5 rounded-full bg-[var(--accent-bg)] hover:bg-[var(--accent)] hover:text-white transition-colors">← {prevDate}</a>
          )}
          <a href={`${base}archive`} class="text-xs text-[var(--text-3)] no-underline px-3.5 py-1.5 rounded-full bg-[var(--accent-bg)] hover:bg-[var(--accent)] hover:text-white transition-colors">Archive</a>
          {nextDate && (
            <a href={`${base}daily/${nextDate}`} class="text-xs text-[var(--text-3)] no-underline px-3.5 py-1.5 rounded-full bg-[var(--accent-bg)] hover:bg-[var(--accent)] hover:text-white transition-colors">{nextDate} →</a>
          )}
        </div>
      </footer>
    </div>
  </main>

  <style>
    .article-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }
    :global([data-theme="dark"]) .article-card:hover {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }
    .line-clamp-3 {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</Base>
