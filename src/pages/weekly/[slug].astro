---
import Base from '../../layouts/Base.astro';
import SCQASection from '../../components/SCQASection.astro';
import InsightCard from '../../components/InsightCard.astro';

export async function getStaticPaths() {
  const files = import.meta.glob('../../../data/weekly/*.json', { eager: true });
  return Object.entries(files).map(([path, mod]: [string, any]) => {
    const d = mod.default || mod;
    return {
      params: { slug: d.week },
      props: { data: d },
    };
  });
}

const { data } = Astro.props;
const base = import.meta.env.BASE_URL;
const weekNum = data.week.split('-W')[1];

// Build prev/next (for now only one week, so just placeholders)
const allFiles = import.meta.glob('../../../data/weekly/*.json', { eager: true });
const allWeeks = Object.entries(allFiles)
  .map(([_, mod]: [string, any]) => (mod.default || mod).week)
  .sort();
const idx = allWeeks.indexOf(data.week);
const prevWeek = idx > 0 ? allWeeks[idx - 1] : null;
const nextWeek = idx < allWeeks.length - 1 ? allWeeks[idx + 1] : null;
---

<Base title={`W${weekNum} 周报 · The Digest`} current="Archive">
  <main style="overflow-x: hidden;">
    <!-- Breadcrumb -->
    <div class="max-w-[1120px] mx-auto px-12 pt-6">
      <div class="flex items-center gap-2 text-xs text-[var(--text-3)]">
        <a href={`${base}archive`} class="no-underline text-[var(--text-3)] hover:text-[var(--accent)] transition-colors">归档</a>
        <span>/</span>
        <span class="text-[var(--text)]">W{weekNum} 周报</span>
      </div>
    </div>

    <!-- Header -->
    <div class="max-w-[1120px] mx-auto px-12">
      <section class="py-10 pb-8 border-b border-[var(--border)]">
        <span class="inline-block text-xs font-bold text-[var(--accent)] bg-[var(--accent-bg)] px-3.5 py-1 rounded-full mb-4">
          W{weekNum}
        </span>
        <h1 class="text-[32px] font-extrabold tracking-tight leading-[1.3] text-[var(--text)] mb-4 max-w-[860px]">
          {data.headline}
        </h1>
        <p class="text-[15px] leading-[1.8] text-[var(--text-2)] max-w-[800px] mb-5">
          {data.summary}
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.date_range}</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.meta.daily_count} 日报</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.meta.article_count} 篇文章</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.meta.source_count} 个源</span>
          <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{data.meta.reading_minutes} 分钟</span>
        </div>
      </section>
    </div>

    <!-- SCQA Executive Summary -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">执行摘要 · SCQA</div>
        <div class="bg-[var(--bg-card)] rounded-[18px] shadow-[var(--shadow)] p-8">
          <SCQASection type="situation" content={data.scqa.situation} />
          <SCQASection type="complication" content={data.scqa.complication} />
          <SCQASection type="question" content={data.scqa.question} />
          <SCQASection type="answer" content={data.scqa.answer} />
        </div>
      </div>
    </div>

    <!-- Logic Diagram (Mermaid) -->
    <div class="max-w-[1120px] mx-auto px-12 py-12">
      <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">逻辑关系图</div>
      <div class="bg-[var(--bg-card)] rounded-[18px] shadow-[var(--shadow)] p-8 flex justify-center">
        <pre class="mermaid">{data.diagram_mermaid}</pre>
      </div>
    </div>

    <!-- Deep Insights -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">深度洞察</div>
        {data.insights.map((ins: any) => (
          <InsightCard
            title={ins.title}
            whyImportant={ins.why_important}
            body={ins.body}
            evidence={ins.evidence}
            action={ins.action}
            surprise={ins.surprise}
          />
        ))}
      </div>
    </div>

    <!-- Blind Spots -->
    <div class="max-w-[1120px] mx-auto px-12 py-12">
      <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">盲点警告</div>
      <div class="flex flex-col gap-4">
        {data.blind_spots.map((bs: string) => (
          <div class="border-l-[3px] border-amber-500 bg-[var(--bg-card)] rounded-r-[14px] shadow-[var(--shadow)] p-5 pl-5">
            <p class="text-sm text-[var(--text-2)] leading-[1.8] m-0">{bs}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Source Traceability -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">来源溯源</div>
        <div class="bg-[var(--bg-card)] rounded-[18px] shadow-[var(--shadow)] overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[var(--border)]">
                <th class="text-left text-[12px] uppercase tracking-[1px] text-[var(--text-3)] font-medium px-6 py-3">洞察</th>
                <th class="text-left text-[12px] uppercase tracking-[1px] text-[var(--text-3)] font-medium px-6 py-3">主要来源</th>
                <th class="text-left text-[12px] uppercase tracking-[1px] text-[var(--text-3)] font-medium px-6 py-3">支撑来源</th>
                <th class="text-left text-[12px] uppercase tracking-[1px] text-[var(--text-3)] font-medium px-6 py-3">可信度</th>
              </tr>
            </thead>
            <tbody>
              {data.source_traceability.map((src: any) => (
                <tr class="border-b border-[var(--border)] last:border-0">
                  <td class="text-[13px] text-[var(--text)] font-medium px-6 py-3">{src.insight}</td>
                  <td class="text-[13px] text-[var(--text-2)] px-6 py-3">{src.primary}</td>
                  <td class="text-[13px] text-[var(--text-3)] px-6 py-3">{src.supporting.join(', ')}</td>
                  <td class="text-[13px] text-[var(--text-2)] px-6 py-3">{src.credibility}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Week Navigation -->
    <div class="max-w-[1120px] mx-auto px-12 py-10">
      <div class="flex justify-between items-center">
        {prevWeek ? (
          <a href={`${base}weekly/${prevWeek}`} class="text-xs px-5 py-2 rounded-full bg-[var(--accent-bg)] text-[var(--accent)] no-underline font-medium hover:opacity-80 transition-opacity">
            ← 上一周
          </a>
        ) : <span />}
        {nextWeek ? (
          <a href={`${base}weekly/${nextWeek}`} class="text-xs px-5 py-2 rounded-full bg-[var(--accent-bg)] text-[var(--accent)] no-underline font-medium hover:opacity-80 transition-opacity">
            下一周 →
          </a>
        ) : <span />}
      </div>
    </div>
  </main>

  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
  <script is:inline>
    mermaid.initialize({ startOnLoad: true, theme: 'neutral', securityLevel: 'loose' });
  </script>
</Base>
