---
import Base from '../../layouts/Base.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import TimelineNode from '../../components/TimelineNode.astro';

export async function getStaticPaths() {
  const files = import.meta.glob('../../../data/events/*.json', { eager: true });
  return Object.entries(files).map(([path, mod]: [string, any]) => {
    const d = mod.default || mod;
    return {
      params: { slug: d.slug },
      props: { data: d },
    };
  });
}

const { data } = Astro.props;
const base = import.meta.env.BASE_URL;

// Reverse timeline so latest is first
const timeline = [...data.timeline].reverse();

// Load related events metadata
const eventFiles = import.meta.glob('../../../data/events/*.json', { eager: true });
const allEvents = Object.entries(eventFiles).map(([_, mod]: [string, any]) => mod.default || mod);
const relatedEvents = (data.related_events || [])
  .map((slug: string) => allEvents.find((e: any) => e.slug === slug))
  .filter(Boolean);

// Key people (simplified — just show names from the list)
const keyPeople = data.key_people || [];
---

<Base title={`${data.title} · The Digest`} current="Events">
  <main style="overflow-x: hidden;">
    <!-- Breadcrumb -->
    <div class="max-w-[1120px] mx-auto px-12 pt-6">
      <div class="flex items-center gap-2 text-xs text-[var(--text-3)]">
        <a href={`${base}events`} class="no-underline text-[var(--text-3)] hover:text-[var(--accent)] transition-colors">Event Tracker</a>
        <span>/</span>
        <span class="text-[var(--text)]">{data.title}</span>
      </div>
    </div>

    <!-- Header -->
    <div class="max-w-[1120px] mx-auto px-12">
      <section class="py-10 pb-8 border-b border-[var(--border)]">
        <div class="flex items-center gap-3 mb-4">
          <StatusBadge status={data.status} />
        </div>
        <h1 class="text-[32px] font-extrabold tracking-tight text-[var(--text)] mb-4 max-w-[860px]">
          {data.title}
        </h1>
        <p class="text-[15px] leading-[1.8] text-[var(--text-2)] max-w-[800px] mb-5">
          {data.description}
        </p>
        <div class="flex flex-wrap gap-2">
          {data.tags.map((tag: string) => (
            <span class="text-xs px-3.5 py-1 rounded-full bg-[var(--accent-bg)] text-[var(--text-3)]">{tag}</span>
          ))}
        </div>
      </section>
    </div>

    <!-- Timeline -->
    <div style="background: var(--bg-alt); margin: 0 -9999px; padding: 48px 9999px;">
      <div class="max-w-[1120px] mx-auto px-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-8 font-medium">Event Timeline</div>
        <div class="timeline-container">
          {timeline.map((node: any, i: number) => (
            <TimelineNode
              date={node.date}
              title={node.title}
              summary={node.summary}
              sources={node.sources}
              isLatest={i === 0}
            />
          ))}
        </div>
      </div>
    </div>

    <!-- Key Players -->
    {keyPeople.length > 0 && (
      <div class="max-w-[1120px] mx-auto px-12 py-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Key Players</div>
        <div class="grid grid-cols-4 gap-4">
          {keyPeople.map((slug: string) => {
            const name = slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
            const initial = name.charAt(0).toUpperCase();
            return (
              <div class="bg-[var(--bg-card)] rounded-[14px] shadow-[var(--shadow)] p-4 flex items-center gap-3">
                <span class="w-10 h-10 rounded-full bg-[var(--accent-bg)] text-[var(--accent)] flex items-center justify-center font-bold text-sm flex-shrink-0">
                  {initial}
                </span>
                <div>
                  <div class="text-sm font-semibold text-[var(--text)]">{name}</div>
                  <div class="text-xs text-[var(--text-3)]">Key role</div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Related Events -->
    {relatedEvents.length > 0 && (
      <div class="max-w-[1120px] mx-auto px-12 pb-12">
        <div class="text-xs uppercase tracking-[2px] text-[var(--text-3)] mb-6 font-medium">Related Events</div>
        <div class="grid grid-cols-2 gap-4">
          {relatedEvents.map((evt: any) => (
            <a href={`${base}events/${evt.slug}`} class="bg-[var(--bg-card)] rounded-[14px] shadow-[var(--shadow)] p-5 no-underline hover:opacity-85 transition-opacity block">
              <div class="flex items-center gap-2 mb-2">
                <StatusBadge status={evt.status} />
                <span class="text-sm font-semibold text-[var(--text)]">{evt.title}</span>
              </div>
              <p class="text-xs text-[var(--text-2)] leading-relaxed m-0">{evt.description.slice(0, 80)}...</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </main>

  <style>
    .timeline-container {
      position: relative;
      padding-left: 10px;
    }
    .timeline-container::before {
      content: '';
      position: absolute;
      left: 19px;
      top: 6px;
      bottom: 32px;
      width: 2px;
      background: var(--border);
    }
  </style>
</Base>
