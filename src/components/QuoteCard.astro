---
interface Props {
  personName: string;
  personSlug: string;
  text: string;
  source: string;
  date: string;
}

const { personName, personSlug, text, source, date } = Astro.props;
const base = import.meta.env.BASE_URL;
const initial = personName.charAt(0).toUpperCase();
---

<div class="quote-card">
  <a href={`${base}people/${personSlug}`} class="avatar">{initial}</a>
  <div class="body">
    <p class="text">"{text}"</p>
    <div class="meta">
      <a href={`${base}people/${personSlug}`} class="name">{personName}</a>
      <span class="source-pill">{source}</span>
      <span class="date">{date}</span>
    </div>
  </div>
</div>

<style>
  .quote-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent-bg);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    flex-shrink: 0;
    text-decoration: none;
  }
  .body {
    flex: 1;
    min-width: 0;
  }
  .text {
    font-size: 14px;
    font-style: italic;
    color: var(--text-2);
    line-height: 1.7;
    margin: 0 0 10px;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
  }
  .name:hover {
    color: var(--accent);
  }
  .source-pill {
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 9999px;
    background: var(--accent-bg);
    color: var(--accent);
  }
  .date {
    font-size: 12px;
    color: var(--text-3);
  }
</style>
