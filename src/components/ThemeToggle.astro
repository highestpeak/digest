<button data-theme-toggle aria-label="Toggle theme">🌙</button>

<style>
  button {
    width: 34px;
    height: 34px;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    line-height: 1;
    padding: 0;
    transition: border-color 0.2s;
  }
  button:hover {
    border-color: var(--accent);
  }
</style>
