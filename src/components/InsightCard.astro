---
interface Props {
  title: string;
  whyImportant: string;
  body: string;
  evidence: string[];
  action: string;
  surprise: boolean;
}

const { title, whyImportant, body, evidence, action, surprise } = Astro.props;
---

<div class="insight-card">
  {surprise && <span class="surprise-marker">&#9889;</span>}
  <h3 class="insight-title">{title}</h3>
  <p class="insight-why">{whyImportant}</p>
  <p class="insight-body">{body}</p>
  {evidence.length > 0 && (
    <div class="insight-evidence">
      {evidence.map((e) => (
        <p class="evidence-item">{e}</p>
      ))}
    </div>
  )}
  <div class="insight-action">
    <span class="action-label">Action</span>
    <span class="action-text">{action}</span>
  </div>
</div>

<style>
  .insight-card {
    position: relative;
    background: var(--bg-card);
    border-radius: 18px;
    box-shadow: var(--shadow);
    padding: 28px;
    margin-bottom: 16px;
  }
  .surprise-marker {
    position: absolute;
    top: 16px;
    right: 20px;
    font-size: 20px;
    color: #f59e0b;
    filter: saturate(1.2);
  }
  .insight-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 8px;
  }
  .insight-why {
    font-size: 14px;
    color: var(--accent);
    font-weight: 500;
    margin: 0 0 14px;
  }
  .insight-body {
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.8;
    margin: 0 0 16px;
  }
  .insight-evidence {
    border-left: 3px solid var(--border);
    padding-left: 16px;
    margin-bottom: 16px;
  }
  .evidence-item {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.7;
    margin: 0 0 6px;
  }
  .insight-action {
    background: var(--accent-bg);
    border-radius: 10px;
    padding: 12px 16px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .action-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
    flex-shrink: 0;
    padding-top: 1px;
  }
  .action-text {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.6;
  }
</style>
