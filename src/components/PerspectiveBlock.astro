---
interface Source {
  name: string;
  quote: string;
}

interface Props {
  title: string;
  subtitle: string;
  eventSlug: string;
  sources: Source[];
}

const { title, subtitle, eventSlug, sources } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}events/${eventSlug}`} class="perspective-block">
  <h3>{title}</h3>
  <p class="subtitle">{subtitle}</p>
  <div class="quotes-grid">
    {sources.map(s => (
      <div class="quote-item">
        <span class="source-name">{s.name}</span>
        <p class="quote-text">{s.quote}</p>
      </div>
    ))}
  </div>
</a>

<style>
  .perspective-block {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }
  .perspective-block:hover {
    opacity: 0.85;
  }
  h3 {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 6px;
    line-height: 1.3;
  }
  .subtitle {
    font-size: 14px;
    color: var(--text-3);
    margin: 0 0 24px;
  }
  .quotes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .quote-item {
    border-left: 3px solid var(--border);
    padding-left: 20px;
  }
  .source-name {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-3);
    display: block;
    margin-bottom: 8px;
  }
  .quote-text {
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.8;
    margin: 0;
  }
</style>
