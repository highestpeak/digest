---
interface Props {
  data: number[];
}

const { data } = Astro.props;

// 84 cells: 12 weeks x 7 days
// GitHub-style: columns = weeks (12), rows = days (7)
// Data is stored week-by-week: [w1d1,w1d2,...w1d7, w2d1,...w2d7, ...]
const weeks = 12;
const days = 7;

const intensityMap: Record<number, string> = {
  0: 'var(--bg-alt)',
  1: 'rgba(37, 99, 235, 0.15)',
  2: 'rgba(37, 99, 235, 0.35)',
  3: 'rgba(37, 99, 235, 0.6)',
  4: 'rgba(37, 99, 235, 0.85)',
};

function getColor(val: number): string {
  if (val <= 0) return intensityMap[0];
  if (val >= 4) return intensityMap[4];
  return intensityMap[val] || intensityMap[0];
}

// Transpose: data[week*7 + day] → grid[day][week]
// Grid renders as 7 rows (days) x 12 columns (weeks)
const grid: number[][] = [];
for (let d = 0; d < days; d++) {
  grid[d] = [];
  for (let w = 0; w < weeks; w++) {
    grid[d].push(data[w * days + d] ?? 0);
  }
}

const dayLabels = ['M', '', 'W', '', 'F', '', ''];
---

<div class="heatmap-wrapper">
  <div class="heatmap-body">
    <div class="heatmap-days">
      {dayLabels.map(label => (
        <div class="day-label">{label}</div>
      ))}
    </div>
    <div class="heatmap-grid">
      {grid.map((row, dayIdx) =>
        row.map((val, weekIdx) => (
          <div
            class="hm-cell"
            style={`background: ${getColor(val)}; grid-row: ${dayIdx + 1}; grid-column: ${weekIdx + 1};`}
            title={`Week ${weekIdx + 1}, Day ${dayIdx + 1}: ${val}`}
          />
        ))
      )}
    </div>
  </div>
  <div class="heatmap-legend">
    <span class="legend-label">Less</span>
    {[0, 1, 2, 3, 4].map(v => (
      <div class="legend-cell" style={`background: ${getColor(v)};`} />
    ))}
    <span class="legend-label">More</span>
  </div>
</div>

<style>
  .heatmap-wrapper {
    width: fit-content;
  }
  .heatmap-body {
    display: flex;
    gap: 4px;
  }
  .heatmap-days {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .day-label {
    width: 16px;
    height: 14px;
    font-size: 10px;
    color: var(--text-3);
    display: flex;
    align-items: center;
  }
  .heatmap-grid {
    display: grid;
    grid-template-columns: repeat(12, 14px);
    grid-template-rows: repeat(7, 14px);
    gap: 3px;
  }
  .hm-cell {
    width: 14px;
    height: 14px;
    border-radius: 3px;
  }
  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
  }
  .legend-label {
    font-size: 10px;
    color: var(--text-3);
  }
  .legend-cell {
    width: 12px;
    height: 12px;
    border-radius: 2px;
  }
</style>
