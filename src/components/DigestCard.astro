---
import CategoryPill from './CategoryPill.astro';

interface Props {
  category: 'ai' | 'geo' | 'econ' | 'indie';
  title: string;
  summary: string;
  sources: string;
  url?: string;
  imageUrl?: string;
}

const { category, title, summary, sources, url, imageUrl } = Astro.props;
---

<article class="digest-card">
  {imageUrl && (
    <div style="margin: -24px -24px 16px -24px; overflow: hidden; border-radius: 18px 18px 0 0;">
      <img src={imageUrl} alt="" style="width: 100%; height: 160px; object-fit: cover; display: block;" loading="lazy" />
    </div>
  )}
  <CategoryPill category={category} />
  {url ? (
    <h3>
      <a href={url} target="_blank" rel="noopener noreferrer" class="title-link">
        {title}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="external-icon">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
    </h3>
  ) : (
    <h3>{title}</h3>
  )}
  <p class="summary">{summary}</p>
  <span class="sources">{sources}</span>
</article>

<style>
  .digest-card {
    background: var(--bg-card);
    border-radius: 18px;
    box-shadow: var(--shadow);
    padding: 24px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .digest-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme="dark"]) .digest-card {
    box-shadow: var(--shadow), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  :global([data-theme="dark"]) .digest-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin: 12px 0 8px;
    line-height: 1.4;
  }
  .title-link {
    color: var(--text);
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
  }
  .title-link:hover {
    color: var(--accent);
  }
  .external-icon {
    flex-shrink: 0;
    opacity: 0.5;
    position: relative;
    top: 1px;
  }
  .title-link:hover .external-icon {
    opacity: 1;
  }
  .summary {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .sources {
    font-size: 11px;
    color: var(--text-3);
  }
</style>
