---
import CategoryPill from './CategoryPill.astro';

interface Props {
  category: 'ai' | 'geo' | 'econ' | 'indie';
  title: string;
  summary: string;
  sources: string;
}

const { category, title, summary, sources } = Astro.props;
---

<article class="digest-card">
  <CategoryPill category={category} />
  <h3>{title}</h3>
  <p class="summary">{summary}</p>
  <span class="sources">{sources}</span>
</article>

<style>
  .digest-card {
    background: var(--bg-card);
    border-radius: 18px;
    box-shadow: var(--shadow);
    padding: 24px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .digest-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme="dark"]) .digest-card {
    box-shadow: var(--shadow), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  :global([data-theme="dark"]) .digest-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin: 12px 0 8px;
    line-height: 1.4;
  }
  .summary {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .sources {
    font-size: 11px;
    color: var(--text-3);
  }
</style>
