---
import StatusBadge from './StatusBadge.astro';

interface Props {
  slug: string;
  title: string;
  status: 'active' | 'watching' | 'resolved';
  description: string;
  tags: string[];
  nodeCount: number;
  lastUpdate: string;
}

const { slug, title, status, description, tags, nodeCount, lastUpdate } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}events/${slug}`} class="event-card">
  <div class="event-left">
    <div class="event-top">
      <StatusBadge status={status} />
      <h3 class="event-title">{title}</h3>
    </div>
    <p class="event-desc">{description}</p>
    <div class="event-tags">
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
  <div class="event-right">
    <span class="node-count">{nodeCount}</span>
    <span class="node-label">时间线节点</span>
    <span class="last-update">{lastUpdate}</span>
  </div>
</a>

<style>
  .event-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    padding: 24px;
    background: var(--bg-card);
    border-radius: 18px;
    box-shadow: var(--shadow);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .event-card:hover {
    opacity: 0.88;
  }
  .event-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .event-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }
  .event-desc {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.7;
    margin: 0 0 10px;
  }
  .event-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 9999px;
    background: var(--accent-bg);
    color: var(--text-3);
  }
  .event-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    text-align: right;
  }
  .node-count {
    font-size: 28px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }
  .node-label {
    font-size: 11px;
    color: var(--text-3);
    margin-top: 4px;
  }
  .last-update {
    font-size: 11px;
    color: var(--text-3);
    margin-top: 8px;
  }
</style>
