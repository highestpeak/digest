---
interface ModelFlash {
  category: string;
  closedSource: string;
  openSource: string;
  bestValue: string;
  change: 'new' | 'none';
}

interface Props {
  data: ModelFlash[];
  baseUrl: string;
}

const { data, baseUrl } = Astro.props;
---

<a href={`${baseUrl}models`} class="table-card">
  <table>
    <thead>
      <tr>
        <th>Category</th>
        <th>Best Closed</th>
        <th>Best Open</th>
        <th>Best Value</th>
        <th>Change</th>
      </tr>
    </thead>
    <tbody>
      {data.map(row => (
        <tr>
          <td>{row.category}</td>
          <td class="model-name">{row.closedSource}</td>
          <td class="model-name">{row.openSource}</td>
          <td class="model-name">{row.bestValue}</td>
          <td>
            {row.change === 'new' ? (
              <span class="badge-new">NEW</span>
            ) : (
              <span class="badge-none">—</span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</a>

<style>
  .table-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--bg-card);
    border-radius: 18px;
    box-shadow: var(--shadow);
    padding: 24px;
    overflow-x: auto;
  }
  :global([data-theme="dark"]) .table-card {
    box-shadow: var(--shadow), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-3);
    text-align: left;
    padding: 12px 16px;
    border-bottom: 2px solid var(--border);
    font-weight: 600;
  }
  td {
    font-size: 14px;
    padding: 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text-2);
  }
  .model-name {
    font-weight: 650;
    color: var(--text);
  }
  .badge-new {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    letter-spacing: 0.5px;
  }
  .badge-none {
    color: var(--text-3);
  }
</style>
